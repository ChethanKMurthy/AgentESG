APP_ENV=development
APP_NAME=esg-ai-platform
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
DATABASE_URL=postgresql+asyncpg://esg:esg@postgres:5432/esg
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_STORE_PATH=/app/data/faiss
DOCUMENTS_PATH=/app/data/documents
